# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/iptc_practice
DATABASE_CHARSET=utf8mb4

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM配置（使用一期的配置）
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 文件上传配置
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp3,mp4,pdf,doc,docx

# 腾讯地图API
TENCENT_MAP_KEY=VI5BZ-CLACQ-W7M5P-47227-NQDOT-5NFKU

# 服务配置
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=True
